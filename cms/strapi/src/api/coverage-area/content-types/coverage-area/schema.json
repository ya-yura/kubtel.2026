{
  "kind": "collectionType",
  "collectionName": "coverage_areas",
  "info": {
    "singularName": "coverage-area",
    "pluralName": "coverage-areas",
    "displayName": "Coverage Area"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "type": {
      "type": "enumeration",
      "enum": [
        "city",
        "district",
        "street",
        "housing_complex",
        "private_sector",
        "business_center",
        "datacenter"
      ],
      "required": true
    },
    "city": { "type": "string", "required": true },
    "district": { "type": "string" },
    "streets": { "type": "json" },
    "houses": { "type": "json" },
    "connectionStatus": {
      "type": "enumeration",
      "enum": ["available", "manual_check", "unavailable", "draft"],
      "default": "draft"
    },
    "availableTariffSlugs": { "type": "json" },
    "availableServiceSlugs": { "type": "json" },
    "contactHint": { "type": "text" },
    "contentSource": { "type": "json" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
