{
  "kind": "collectionType",
  "collectionName": "design_themes",
  "info": {
    "singularName": "design-theme",
    "pluralName": "design-themes",
    "displayName": "Design Theme"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "pageAccent": {
      "type": "enumeration",
      "enum": ["default", "business", "critical"],
      "default": "default"
    },
    "heroVariant": {
      "type": "enumeration",
      "enum": ["standard", "business", "compact", "proof-led"],
      "default": "standard"
    },
    "sectionDensity": {
      "type": "enumeration",
      "enum": ["comfortable", "compact", "dense"],
      "default": "comfortable"
    },
    "ctaVariant": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "business", "critical"],
      "default": "primary"
    },
    "serviceCardLayout": {
      "type": "enumeration",
      "enum": ["grid", "list", "comparison"],
      "default": "grid"
    },
    "proofVisibility": { "type": "boolean", "default": true },
    "allowedTokenRefs": { "type": "json" },
    "notes": { "type": "text" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
