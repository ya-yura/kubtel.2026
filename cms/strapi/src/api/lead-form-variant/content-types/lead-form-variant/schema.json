{
  "kind": "collectionType",
  "collectionName": "lead_form_variants",
  "info": {
    "singularName": "lead-form-variant",
    "pluralName": "lead-form-variants",
    "displayName": "Lead Form Variant"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "leadType": {
      "type": "enumeration",
      "enum": ["b2c", "b2b", "datacenter_access", "operator_partner"],
      "required": true
    },
    "formKey": { "type": "string", "required": true },
    "fields": { "type": "json" },
    "requiredFields": { "type": "json" },
    "routingKey": { "type": "string", "required": true },
    "crmPipeline": {
      "type": "enumeration",
      "enum": ["b2c", "b2b", "operators", "datacenter"],
      "required": true
    },
    "consentDocumentSlug": { "type": "string", "required": true },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
