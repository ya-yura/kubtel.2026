{
  "kind": "collectionType",
  "collectionName": "calculator_options",
  "info": {
    "singularName": "calculator-option",
    "pluralName": "calculator-options",
    "displayName": "Calculator Option"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "fieldKey": { "type": "string", "required": true },
    "inputType": {
      "type": "enumeration",
      "enum": ["select", "number", "checkbox", "radio", "slider"],
      "required": true
    },
    "valueType": {
      "type": "enumeration",
      "enum": ["string", "number", "boolean"],
      "required": true
    },
    "unit": { "type": "string" },
    "min": { "type": "decimal" },
    "max": { "type": "decimal" },
    "step": { "type": "decimal" },
    "defaultValue": { "type": "json" },
    "priceMonthly": { "type": "integer" },
    "priceOneTime": { "type": "integer" },
    "requiredConsultation": { "type": "boolean", "default": true },
    "sortOrder": { "type": "integer", "default": 100 },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
