{
  "kind": "collectionType",
  "collectionName": "promos",
  "info": {
    "singularName": "promo",
    "pluralName": "promos",
    "displayName": "Promo"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "startDate": { "type": "date", "required": true },
    "endDate": { "type": "date" },
    "description": { "type": "text", "required": true },
    "conditions": { "type": "json" },
    "relatedTariffSlugs": { "type": "json" },
    "relatedServiceSlugs": { "type": "json" },
    "targetArea": { "type": "string" },
    "ctaLabel": { "type": "string", "required": true },
    "proof": { "type": "json" },
    "contentSource": { "type": "json" },
    "commercialReview": { "type": "json" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
