{
  "kind": "collectionType",
  "collectionName": "business_segments",
  "info": {
    "singularName": "business-segment",
    "pluralName": "business-segments",
    "displayName": "Business Segment"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "audience": { "type": "json" },
    "painPoints": { "type": "json" },
    "triggers": { "type": "json" },
    "primaryCta": { "type": "string", "required": true },
    "relatedServiceSlugs": { "type": "json" },
    "formVariantSlug": { "type": "string" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
