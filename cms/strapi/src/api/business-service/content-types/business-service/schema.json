{
  "kind": "collectionType",
  "collectionName": "business_services",
  "info": {
    "singularName": "business-service",
    "pluralName": "business-services",
    "displayName": "Business Service"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "category": {
      "type": "enumeration",
      "enum": [
        "internet",
        "telephony",
        "cctv",
        "wifi_auth",
        "vps",
        "vdi",
        "colocation",
        "datacenter_access",
        "operators",
        "government"
      ],
      "required": true
    },
    "summary": { "type": "text", "required": true },
    "businessBenefit": { "type": "text", "required": true },
    "proofPoints": { "type": "json" },
    "ctaLabel": { "type": "string", "required": true },
    "priority": { "type": "enumeration", "enum": ["P0", "P1", "P2"], "default": "P1" },
    "relatedSegmentSlugs": { "type": "json" },
    "calculatorSlug": { "type": "string" },
    "formVariantSlug": { "type": "string" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    },
    "verificationStatus": {
      "type": "enumeration",
      "enum": ["confirmed", "needs_verification", "draft"],
      "default": "draft"
    }
  }
}
