{
  "kind": "collectionType",
  "collectionName": "tariffs",
  "info": {
    "singularName": "tariff",
    "pluralName": "tariffs",
    "displayName": "Tariff"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "market": { "type": "enumeration", "enum": ["b2c", "b2b"], "default": "b2c" },
    "audience": { "type": "json" },
    "speedDownload": { "type": "integer" },
    "speedUpload": { "type": "integer" },
    "priceMonth": { "type": "integer" },
    "promoPrice": { "type": "integer" },
    "promoPeriod": { "type": "string" },
    "benefitDescription": { "type": "text", "required": true },
    "bestFor": { "type": "json" },
    "includedServices": { "type": "json" },
    "availableOptionSlugs": { "type": "json" },
    "isFeatured": { "type": "boolean", "default": false },
    "sortOrder": { "type": "integer", "default": 100 },
    "proof": { "type": "json" },
    "contentSource": { "type": "json" },
    "commercialReview": { "type": "json" },
    "workflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "ready_for_review",
        "commercial_approved",
        "legal_approved",
        "published",
        "archived"
      ],
      "default": "draft"
    }
  }
}
