---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAbsoluteUrl, getSitePath } from "@config/site";
import { businessProofStrip, businessSegments, businessServices } from "@lib/business/content";
import type { JsonLdObject } from "@lib/seo/schema";

const pageSchema: JsonLdObject = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${getAbsoluteUrl("/business/")}#business-services`,
  name: "Kubtel для бизнеса",
  serviceType: "Телеком-услуги для бизнеса",
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Краснодар и Краснодарский край"
  },
  provider: {
    "@type": "Organization",
    name: "Kubtel",
    url: getAbsoluteUrl("/")
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "B2B-услуги Kubtel",
    itemListElement: businessServices.map((service, index) => ({
      "@type": "Offer",
      position: index + 1,
      name: service.title,
      url: getAbsoluteUrl(`/business/${service.slug}/`)
    }))
  }
};
---

<BaseLayout
  title="Kubtel для бизнеса"
  description="Kubtel для бизнеса Краснодара: стабильная связь, поддержка 24/7, аварийная бригада в течение часа, персональный менеджер и Hot-spot."
  canonicalPath="/business/"
  schema={pageSchema}
>
  <section class="business-hero section-pad">
    <div class="business-hero-copy">
      <p class="eyebrow">Бизнесу</p>
      <h1>Связь для бизнеса, где простой дороже тарифа</h1>
      <p>
        Федерал может быть на 20% дешевле, пока все работает. Но когда канал падает, кассы, CRM,
        телефония и оплата встают вместе с ним. Kubtel выбирают за стабильность, живую поддержку и
        быстрый выезд.
      </p>
      <div class="business-actions">
        <a class="card-action" href={getSitePath("/business/request/")}>Получить расчет</a>
        <a class="business-link" href={getSitePath("/business/internet/")}>Защитить канал</a>
      </div>
    </div>
    <div class="business-hero-panel" aria-label="Ключевые факты Kubtel для бизнеса">
      {
        businessProofStrip.map((proof) => (
          <article>
            <span>{proof.label}</span>
            <strong>{proof.value}</strong>
            <small>{proof.status}</small>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-pad narrative-section">
    <h2>История, которую понимает любой офис</h2>
    <p>
      Компания работала на дешевом канале известного провайдера, пока авария не оставила ее без
      интернета на двое суток. В поддержке через час ответили только одно: авария на линии, сроки
      неизвестны.
    </p>
    <p>
      После обращения в Kubtel монтажник приехал на следующий день и провел оптику. Цена оказалась
      немного выше, но скорость решения вопроса стала важнее скидки. Компания работает с Kubtel уже
      больше пяти лет.
    </p>
  </section>

  <section class="section-pad">
    <div class="section-heading">
      <p class="eyebrow">Услуги</p>
      <h2>Не набор услуг, а защита рабочих процессов</h2>
      <p>
        Интернет, телефония, видеонаблюдение, гостевой Wi-Fi Hot-spot и инфраструктура собираются
        вокруг задачи: чтобы бизнес не останавливался.
      </p>
    </div>
    <div class="business-card-grid">
      {
        businessServices.map((service) => (
          <article class="business-card">
            <span class="service-category">{service.category}</span>
            <h3>{service.title}</h3>
            <p>{service.summary}</p>
            <ul class="business-mini-list">
              {service.proofPoints.slice(0, 2).map((proof) => (
                <li>
                  {proof.label}: {proof.value}
                </li>
              ))}
            </ul>
            <a class="card-action" href={getSitePath(`/business/${service.slug}/`)}>
              {service.ctaLabel}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-pad business-band">
    <div class="section-heading">
      <p class="eyebrow">Сегменты</p>
      <h2>От кафе с гостевым Wi-Fi до операторской инфраструктуры</h2>
    </div>
    <div class="business-segment-grid">
      {
        businessSegments.map((segment) => (
          <article class="business-segment-card">
            <h3>{segment.title}</h3>
            <p>{segment.summary}</p>
            <strong>{segment.trigger}</strong>
            <a href={getSitePath(`/business/${segment.slug}/`)}>{segment.ctaLabel}</a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
