---
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  businessSegments,
  businessServices,
  getBusinessSegment,
  getBusinessService
} from "@lib/business/content";
import { handleBusinessLeadFormPost } from "@lib/leads/form-handlers";

const isStaticPreview = import.meta.env.PUBLIC_STATIC_PREVIEW === "true";
export const prerender = false;

const selectedService = Astro.url.searchParams.get("service") ?? "";
const selectedSegment = Astro.url.searchParams.get("segment") ?? "";
const service = selectedService ? getBusinessService(selectedService) : undefined;
const segment = selectedSegment ? getBusinessSegment(selectedSegment) : undefined;
const contextTitle = service?.title ?? segment?.title ?? "B2B-заявка";
const formStartedAt = Date.now().toString();
const actionResult = isStaticPreview
  ? undefined
  : Astro.request.method === "POST"
    ? await handleBusinessLeadFormPost(await Astro.request.formData(), Astro.request)
    : undefined;
const actionData = actionResult?.data;
const actionError = actionResult?.error;
---

<BaseLayout
  title="Заявка для бизнеса"
  description="B2B-заявка Kubtel: компания, контакт, услуга, сегмент, срочность и конфигурация для расчета."
  canonicalPath="/business/request/"
  pageType="ContactPage"
>
  <section class="page-intro section-pad business-page-intro">
    <p class="eyebrow">B2B-заявка</p>
    <h1>Расскажите, что нужно подключить для бизнеса</h1>
    <p>
      Передайте компанию, контакт, услугу и срочность. Для неподтвержденных цен заявка уходит как
      индивидуальный расчет.
    </p>
  </section>

  <section class="section-pad business-request-layout" id="business-request">
    <form
      class="business-request-form"
      method="post"
      action={isStaticPreview ? "#business-request" : Astro.url.pathname}
      data-business-request-form
      data-static-preview={isStaticPreview ? "true" : undefined}
    >
      {
        actionData && (
          <div class="form-status is-success" id="business-form-status" role="status" tabindex="-1">
            <strong>{actionData.message}</strong>
            <span>Номер заявки: {actionData.leadId}</span>
          </div>
        )
      }
      {
        actionError && (
          <div class="form-status is-error" id="business-form-status" role="alert" tabindex="-1">
            <strong>B2B-заявка не отправлена</strong>
            <span>{actionError.message ?? "Проверьте поля и попробуйте еще раз."}</span>
          </div>
        )
      }
      <input name="sourcePath" type="hidden" value={Astro.url.pathname} />
      <input name="formStartedAt" type="hidden" value={formStartedAt} />
      <label class="visually-hidden">
        <span>Оставьте это поле пустым</span>
        <input name="website" type="text" tabindex="-1" autocomplete="off" />
      </label>
      <fieldset class="form-group">
        <legend>Компания и контакт</legend>
        <div class="contact-grid">
          <label>
            Компания
            <input
              name="companyName"
              type="text"
              autocomplete="organization"
              maxlength="160"
              required
            />
          </label>
          <label>
            Контактное лицо
            <input name="contactPerson" type="text" autocomplete="name" maxlength="120" required />
          </label>
          <label>
            Телефон
            <input
              name="phone"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              maxlength="32"
              required
            />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="email" maxlength="120" />
          </label>
          <label>
            ИНН
            <input name="inn" type="text" inputmode="numeric" maxlength="12" />
          </label>
        </div>
      </fieldset>

      <fieldset class="form-group">
        <legend>Задача</legend>
        <div class="contact-grid">
          <label>
            Сегмент
            <select name="segment">
              <option value="">Выберите сегмент</option>
              {
                businessSegments.map((item) => (
                  <option value={item.slug} selected={item.slug === selectedSegment}>
                    {item.title}
                  </option>
                ))
              }
            </select>
          </label>
          <label>
            Услуга
            <select name="service" required>
              <option value="">Выберите услугу</option>
              {
                businessServices.map((item) => (
                  <option value={item.slug} selected={item.slug === selectedService}>
                    {item.title}
                  </option>
                ))
              }
            </select>
          </label>
          <label>
            Город или адрес
            <input name="city" type="text" autocomplete="street-address" maxlength="200" />
          </label>
          <label>
            Адрес объекта
            <input name="address" type="text" autocomplete="street-address" maxlength="240" />
          </label>
          <label>
            Сотрудников или площадок
            <input name="employeesOrSites" type="number" min="0" step="1" inputmode="numeric" />
          </label>
          <label>
            Срочность
            <select name="urgency">
              <option value="planning">Планируем</option>
              <option value="30_days">До 30 дней</option>
              <option value="7_days">До 7 дней</option>
              <option value="asap">Срочно</option>
            </select>
          </label>
        </div>
      </fieldset>

      <label class="message-field">
        Конфигурация или комментарий
        <textarea
          name="configurationSummary"
          rows="5"
          maxlength="1200"
          placeholder="Например: офис на 20 сотрудников, нужен интернет 300 Мбит/с, 2 статических IP и телефония"
        ></textarea>
      </label>

      <label class="message-field">
        Дополнительный комментарий
        <textarea
          name="message"
          rows="3"
          maxlength="800"
          placeholder="Например: удобное время звонка, текущий подрядчик, ограничения по срокам"
        ></textarea>
      </label>

      <label class="consent-line">
        <input type="checkbox" name="consent" required />
        <span>Согласен на обработку данных для связи по заявке.</span>
      </label>

      <button type="submit">Отправить B2B-заявку</button>
      <p class="form-note">
        B2B-заявка обрабатывается отдельно от домашнего подключения. Цены и SLA уточняются после
        коммерческой проверки.
      </p>
    </form>

    <aside class="business-request-summary" aria-label="Контекст заявки">
      <span class="service-category">Контекст</span>
      <h2>{contextTitle}</h2>
      <p>
        Поля B2B-заявки уже отделены от домашнего подключения: компания, сегмент, услуга, срочность
        и конфигурация.
      </p>
      <ul class="business-mini-list">
        <li>Отдельная обработка бизнес-заявок</li>
        <li>Индивидуальный расчет при неподтвержденной цене</li>
        <li>Контекст услуги передается вместе с заявкой</li>
      </ul>
    </aside>
  </section>
</BaseLayout>

<script>
  const businessForm = document.querySelector<HTMLFormElement>("[data-business-request-form]");

  if (businessForm?.dataset.staticPreview === "true") {
    businessForm.addEventListener("submit", (event) => {
      if (!businessForm.checkValidity()) {
        return;
      }

      event.preventDefault();
      showBusinessPreviewStatus(businessForm);
    });
  }

  function showBusinessPreviewStatus(form: HTMLFormElement) {
    const existingStatus = form.querySelector<HTMLElement>("#business-form-status");
    const status = existingStatus ?? document.createElement("div");
    const company =
      form.querySelector<HTMLInputElement>('input[name="companyName"]')?.value.trim() || "Компания";
    const service = form.querySelector<HTMLSelectElement>('select[name="service"]');
    const serviceTitle = service?.selectedOptions[0]?.textContent?.trim() || "выбранная услуга";

    status.className = "form-status is-success";
    status.id = "business-form-status";
    status.setAttribute("role", "status");
    status.setAttribute("tabindex", "-1");
    status.replaceChildren(
      createBusinessStatusLine("strong", "Демо B2B-заявка принята в онлайн-превью."),
      createBusinessStatusLine("span", `${company}: ${serviceTitle}.`),
      createBusinessStatusLine(
        "span",
        "Для боевой отправки подключите Node-хостинг, CRM, Telegram и analytics env."
      )
    );

    if (!existingStatus) {
      form.prepend(status);
    }

    status.focus({ preventScroll: true });
  }

  function createBusinessStatusLine(tagName: "strong" | "span", text: string) {
    const element = document.createElement(tagName);
    element.textContent = text;

    return element;
  }
</script>
