---
import BaseLayout from "@layouts/BaseLayout.astro";
import TariffGrid from "@components/sections/TariffGrid.astro";
import TariffComparison from "@components/sections/TariffComparison.astro";
import AddressCheckPanel from "@components/sections/AddressCheckPanel.astro";
import { getTariffs } from "@lib/content";
import { handleLeadFormPost } from "@lib/leads/form-handlers";
import { buildInternetServiceSchema, buildOfferCatalogSchema } from "@lib/seo/schema";

const isStaticPreview = import.meta.env.PUBLIC_STATIC_PREVIEW === "true";
export const prerender = false;

const tariffs = await getTariffs();
const leadActionResult =
  !isStaticPreview && Astro.request.method === "POST"
    ? await handleLeadFormPost(await Astro.request.formData(), Astro.request)
    : undefined;
const pageSchema = [
  buildInternetServiceSchema(tariffs, "/tariffs/"),
  buildOfferCatalogSchema(tariffs, "/tariffs/")
];
---

<BaseLayout
  title="Тарифы домашнего интернета"
  description="Сравнение тарифов Kubtel для квартиры, семьи, удаленной работы и ТВ с переходом к обратному звонку."
  canonicalPath="/tariffs/"
  pageType="CollectionPage"
  schema={pageSchema}
>
  <section class="page-intro section-pad">
    <p class="eyebrow">Тарифы Kubtel</p>
    <h1>Понятная скорость, понятная цена, понятный следующий шаг</h1>
    <p>
      Тарифы помогают сориентироваться до звонка. Дальше специалист уточнит задачу и предложит
      вариант без скрытых платежей и навязанных услуг.
    </p>
  </section>
  <TariffGrid
    tariffs={tariffs}
    title="Выберите базовый сценарий"
    lead="Каждая карточка объясняет, кому подходит тариф: работа, семейный вечер, фильмы, игры или запас скорости."
  />
  <TariffComparison tariffs={tariffs} />
  <AddressCheckPanel
    tariffs={tariffs}
    title="Оставьте телефон - подберем тариф голосом, а не анкетой"
    actionResult={leadActionResult}
    staticPreview={isStaticPreview}
    formAction={Astro.url.pathname}
  />
</BaseLayout>
