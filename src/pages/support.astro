---
import BaseLayout from "@layouts/BaseLayout.astro";
import FaqList from "@components/sections/FaqList.astro";
import SupportPathways from "@components/sections/SupportPathways.astro";
import { getFaqItems } from "@lib/content";
import { buildFaqSchema } from "@lib/seo/schema";

const faqItems = await getFaqItems();
const pageSchema = buildFaqSchema(faqItems, "/support/");
---

<BaseLayout
  title="Поддержка и FAQ"
  description="Поддержка Kubtel: живое обращение, понятные условия, бесплатный доверительный платеж и добровольная блокировка до полугода."
  canonicalPath="/support/"
  schema={pageSchema}
>
  <section class="page-intro section-pad">
    <p class="eyebrow">Поддержка</p>
    <h1>Поддержка должна объяснять, а не прятаться за регламентом</h1>
    <p>
      Самая сильная ценность Kubtel проявляется не в красивой скорости на баннере, а когда человеку
      нужно решить вопрос без волокиты, скриптов и бесконечных переводов между отделами.
    </p>
  </section>
  <SupportPathways />
  <FaqList items={faqItems} />
</BaseLayout>
