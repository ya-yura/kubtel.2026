---
import BaseLayout from "@layouts/BaseLayout.astro";
import AddressCheckPanel from "@components/sections/AddressCheckPanel.astro";
import { getTariffs } from "@lib/content";
import { handleLeadFormPost } from "@lib/leads/form-handlers";
import { buildInternetServiceSchema } from "@lib/seo/schema";

const isStaticPreview = import.meta.env.PUBLIC_STATIC_PREVIEW === "true";
export const prerender = false;

const tariffs = await getTariffs();

const selectedTariff = Astro.url.searchParams.get("tariff");
const initialAddress = Astro.url.searchParams.get("address");
const initialPhone = Astro.url.searchParams.get("phone");
const leadActionResult =
  !isStaticPreview && Astro.request.method === "POST"
    ? await handleLeadFormPost(await Astro.request.formData(), Astro.request)
    : undefined;
const pageSchema = buildInternetServiceSchema(tariffs, "/connect/");
---

<BaseLayout
  title="Заявка на подключение"
  description="Оставьте телефон для обратного звонка Kubtel: специалист уточнит задачу и предложит подключение без скрытых условий."
  canonicalPath="/connect/"
  schema={pageSchema}
>
  <section class="page-intro section-pad">
    <p class="eyebrow">Подключение</p>
    <h1>Оставьте телефон - мы перезвоним и разберемся по-человечески</h1>
    <p>
      Адрес можно назвать уже в разговоре. Главное - получить контакт, быстро понять вашу ситуацию
      и предложить надежный домашний интернет без скрытых платежей и лишней бюрократии.
    </p>
  </section>
  <AddressCheckPanel
    tariffs={tariffs}
    selectedTariff={selectedTariff}
    initialAddress={initialAddress}
    initialPhone={initialPhone}
    actionResult={leadActionResult}
    staticPreview={isStaticPreview}
    formAction={Astro.url.pathname}
  />
</BaseLayout>
