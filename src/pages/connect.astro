---
import { actions } from "astro:actions";
import BaseLayout from "@layouts/BaseLayout.astro";
import AddressCheckPanel from "@components/sections/AddressCheckPanel.astro";
import AddressStateMap from "@components/sections/AddressStateMap.astro";
import { getTariffs } from "@lib/content";
import { buildInternetServiceSchema } from "@lib/seo/schema";

const isStaticPreview = import.meta.env.PUBLIC_STATIC_PREVIEW === "true";
export const prerender = false;

const tariffs = await getTariffs();

const selectedTariff = Astro.url.searchParams.get("tariff");
const initialAddress = Astro.url.searchParams.get("address");
const leadActionResult = isStaticPreview ? undefined : Astro.getActionResult(actions.submitLead);
const pageSchema = buildInternetServiceSchema(tariffs, "/connect/");
---

<BaseLayout
  title="Проверка адреса подключения"
  description="Форма заявки Kubtel: адрес, тариф, опции, контакт и серверная проверка возможности подключения."
  canonicalPath="/connect/"
  schema={pageSchema}
>
  <section class="page-intro section-pad">
    <p class="eyebrow">Подключение</p>
    <h1>Проверим адрес и подберем понятный тариф</h1>
    <p>
      Этот сценарий станет основой конверсионной воронки: адрес, тариф, опции, заявка, уведомление
      отдела продаж.
    </p>
  </section>
  <AddressCheckPanel
    tariffs={tariffs}
    selectedTariff={selectedTariff}
    initialAddress={initialAddress}
    actionResult={leadActionResult}
    staticPreview={isStaticPreview}
  />
  <AddressStateMap />
</BaseLayout>
