---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/sections/Hero.astro";
import FunnelOverview from "@components/sections/FunnelOverview.astro";
import TariffGrid from "@components/sections/TariffGrid.astro";
import HumanScenarios from "@components/sections/HumanScenarios.astro";
import ServiceCards from "@components/sections/ServiceCards.astro";
import FaqList from "@components/sections/FaqList.astro";
import AddressCheckPanel from "@components/sections/AddressCheckPanel.astro";
import { getFaqItems, getServices, getTariffs } from "@lib/content";
import { handleLeadFormPost } from "@lib/leads/form-handlers";
import { buildFaqSchema, buildInternetServiceSchema } from "@lib/seo/schema";

const isStaticPreview = import.meta.env.PUBLIC_STATIC_PREVIEW === "true";
export const prerender = false;

const tariffs = await getTariffs();
const services = await getServices();
const faqItems = await getFaqItems({ limit: 3 });
const leadActionResult =
  !isStaticPreview && Astro.request.method === "POST"
    ? await handleLeadFormPost(await Astro.request.formData(), Astro.request)
    : undefined;
const pageSchema = [buildInternetServiceSchema(tariffs, "/"), buildFaqSchema(faqItems, "/")];
---

<BaseLayout
  title="Интернет в Краснодаре"
  description="Kubtel: домашний интернет в Краснодаре с живым обратным звонком, понятными условиями и локальной командой без скрытых платежей."
  canonicalPath="/"
  schema={pageSchema}
>
  <Hero />
  <FunnelOverview />
  <HumanScenarios />
  <ServiceCards services={services} tariffs={tariffs} />
  <TariffGrid tariffs={tariffs} />
  <AddressCheckPanel
    tariffs={tariffs}
    actionResult={leadActionResult}
    staticPreview={isStaticPreview}
    formAction={Astro.url.pathname}
  />
  <FaqList items={faqItems} />
</BaseLayout>
