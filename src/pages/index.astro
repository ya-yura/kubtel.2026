---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/sections/Hero.astro";
import FunnelOverview from "@components/sections/FunnelOverview.astro";
import TariffGrid from "@components/sections/TariffGrid.astro";
import HumanScenarios from "@components/sections/HumanScenarios.astro";
import FaqList from "@components/sections/FaqList.astro";
import AddressCheckPanel from "@components/sections/AddressCheckPanel.astro";
import type { Tariff } from "@models/domain";

const tariffEntries = await getCollection("tariffs");
const tariffs = tariffEntries
  .map((entry) => entry.data as Tariff)
  .sort((a, b) => a.sortOrder - b.sortOrder);

const faqEntries = await getCollection("faq");
const faqItems = faqEntries
  .map((entry) => entry.data)
  .sort((a, b) => a.priority - b.priority)
  .slice(0, 3);
---

<BaseLayout
  title="Интернет в Краснодаре"
  description="Kubtel: домашний интернет, ТВ и подключение по адресу в Краснодаре."
>
  <Hero />
  <FunnelOverview />
  <HumanScenarios />
  <TariffGrid tariffs={tariffs} />
  <AddressCheckPanel tariffs={tariffs} />
  <FaqList items={faqItems} />
</BaseLayout>
