---
import { mainNavItems } from "@config/routes";
import { getSitePath, SITE } from "@config/site";

const currentPath = Astro.url.pathname;

function isCurrentPath(href: string) {
  return href === "/" ? currentPath === href : currentPath.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href={getSitePath("/")} aria-label={`${SITE.name}, на главную`}>
    <span class="brand-mark">K</span>
    <span>{SITE.name}</span>
  </a>
  <nav class="site-nav" aria-label="Основная навигация">
    {
      mainNavItems.map((item) => (
        <a
          href={getSitePath(item.href)}
          aria-current={isCurrentPath(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <details class="mobile-nav">
    <summary aria-label="Открыть основное меню">
      <span class="nav-toggle-lines" aria-hidden="true"></span>
      <span class="visually-hidden">Открыть основное меню</span>
    </summary>
    <nav aria-label="Мобильная навигация" id="mobile-nav-panel">
      {
        mainNavItems.map((item) => (
          <a
            href={getSitePath(item.href)}
            aria-current={isCurrentPath(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a
        class="mobile-nav-account"
        href={SITE.accountUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Личный кабинет
      </a>
      <a class="mobile-nav-action" href={getSitePath("/connect/#address-check")}>Проверить адрес</a>
    </nav>
  </details>
  <a class="header-account" href={SITE.accountUrl} target="_blank" rel="noopener noreferrer">
    Личный кабинет
  </a>
  <a class="header-action" href={getSitePath("/connect/#address-check")}>Проверить адрес</a>
</header>
