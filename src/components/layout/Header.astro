---
const navItems = [
  { href: "/tariffs/", label: "Тарифы" },
  { href: "/connect/", label: "Подключение" },
  { href: "/support/", label: "Поддержка" },
  { href: "/about/", label: "О компании" },
  { href: "/contacts/", label: "Контакты" }
];

const currentPath = Astro.url.pathname;

function isCurrentPath(href: string) {
  return href === "/" ? currentPath === href : currentPath.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Kubtel, на главную">
    <span class="brand-mark">K</span>
    <span>Kubtel</span>
  </a>
  <nav class="site-nav" aria-label="Основная навигация">
    {navItems.map((item) => (
      <a href={item.href} aria-current={isCurrentPath(item.href) ? "page" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
  <a class="header-action" href="/connect/#address-check">Проверить адрес</a>
</header>
