---
import { getSitePath } from "@config/site";

const isBusinessPath = Astro.url.pathname.startsWith("/business/");
const label = isBusinessPath ? "B2B-заявка" : "Оставить телефон";
const hint = isBusinessPath ? "Для расчета услуги" : "Перезвоним с предложением";
const href = isBusinessPath ? "/business/request/" : "/connect/#callback-request";
const actionLabel = isBusinessPath ? "Оставить" : "Начать";
---

<aside class="sticky-cta" aria-label={label}>
  <div>
    <strong>{label}</strong>
    <span>{hint}</span>
  </div>
  <a href={getSitePath(href)} aria-label={label}>{actionLabel}</a>
</aside>
