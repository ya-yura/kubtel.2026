---
import { getSitePath, SITE } from "@config/site";
---

<section class="hero section-pad">
  <div class="hero-copy">
    <p class="eyebrow">Краснодар, квартиры, ЖК и частный сектор</p>
    <h1>Интернет Kubtel для дома, работы и спокойных вечеров</h1>
    <p class="hero-lead">
      Проверяем адрес, показываем понятные условия и передаем заявку локальной команде без лишней
      бюрократии.
    </p>
    <div class="audience-switch" aria-label="Выберите направление">
      <a class="audience-card is-active" href={getSitePath("/connect/#address-check")}>
        <span>Для физиков</span>
        <strong>Домашний интернет</strong>
        <small>Адрес, тарифы, ТВ и заявка на подключение.</small>
      </a>
      <a class="audience-card" href={getSitePath("/business/")}>
        <span>Для бизнеса</span>
        <strong>Юрлица и ИП</strong>
        <small>Интернет в офис, телефония, камеры, VPS и размещение.</small>
      </a>
      <a class="audience-login" href={SITE.accountUrl} target="_blank" rel="noopener noreferrer">
        Личный кабинет абонента
      </a>
    </div>
    <form
      class="address-inline"
      action={getSitePath("/connect/#address-check")}
      method="get"
      aria-label="Быстрая проверка адреса"
    >
      <label>
        <span>Адрес подключения</span>
        <input
          name="address"
          type="text"
          placeholder="Улица, дом, квартира"
          autocomplete="street-address"
        />
      </label>
      <button type="submit">Проверить</button>
    </form>
  </div>
  <div class="hero-panel" aria-label="Ключевые преимущества">
    <div>
      <span class="metric">3-5</span>
      <p>действий до заявки в целевой воронке</p>
    </div>
    <div>
      <span class="metric">0</span>
      <p>скрытых условий в интерфейсе тарифа</p>
    </div>
    <div>
      <span class="metric">local</span>
      <p>фокус на районах, ЖК и частном секторе Краснодара</p>
    </div>
  </div>
</section>
