---
import { getVerificationLabel } from "@lib/verification";
import type { ProofPoint } from "@models/domain";

type FaqItem = {
  question: string;
  answer: string;
  priority: number;
  proof?: ProofPoint;
};

type Props = {
  items: FaqItem[];
};

const { items } = Astro.props;
---

<section class="section-pad faq-section">
  <div class="section-heading">
    <p class="eyebrow">FAQ</p>
    <h2>Ответы, которые снимают тревогу</h2>
  </div>
  <div class="faq-list">
    {items.map((item) => (
      <details>
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
        {item.proof && (
          <p class:list={["data-status", item.proof.status]}>
            {getVerificationLabel(item.proof.status)}: {item.proof.value}
          </p>
        )}
      </details>
    ))}
  </div>
</section>
