---
const addressStates = [
  {
    status: "available",
    label: "Телефон получен",
    title: "Заявка сразу попадает к специалисту",
    description:
      "Главный результат формы - контакт для живого звонка, а не обещание автоматического ответа."
  },
  {
    status: "manual",
    label: "Детали уточняются",
    title: "Район и задачу проговаривают голосом",
    description:
      "Адрес, дом, тариф и дополнительные пожелания можно спокойно уточнить уже в разговоре."
  },
  {
    status: "unavailable",
    label: "Нет ложных обещаний",
    title: "Не продаем невозможное заранее",
    description:
      "Если подключение не подходит по условиям, менеджер говорит об этом прямо и предлагает альтернативу."
  },
  {
    status: "error",
    label: "Ошибка формы",
    title: "Просим поправить телефон",
    description:
      "Форма не отправляет пустой контакт в отдел продаж и помогает исправить номер."
  }
];
---

<section class="section-pad state-map-section" id="address-states">
  <div class="section-heading">
    <p class="eyebrow">Состояния формы</p>
    <h2>Заявка должна быть понятной после одного номера</h2>
    <p>Этот блок описывает поведение phone-first формы для будущих доработок CRM и аналитики.</p>
  </div>
  <div class="state-grid">
    {
      addressStates.map((item) => (
        <article class:list={["state-card", item.status]}>
          <span>{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))
    }
  </div>
</section>
