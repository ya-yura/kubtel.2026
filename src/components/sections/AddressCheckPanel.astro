---
import { formatRubles } from "@lib/format";
import { calculateMonthlyPrice } from "@lib/pricing";
import type { LeadActionResult } from "@lib/leads/submission";
import type { Tariff, TariffOption } from "@models/domain";

type LeadActionResultLike = {
  data?: LeadActionResult;
  error?: {
    message?: string;
  };
};

type Props = {
  title?: string;
  lead?: string;
  tariffs?: Tariff[];
  selectedTariff?: string | null;
  initialAddress?: string | null;
  initialPhone?: string | null;
  actionResult?: LeadActionResultLike;
  staticPreview?: boolean;
  formAction?: string;
};

const {
  title = "Оставьте телефон - специалист Kubtel перезвонит",
  lead = "Никакой имитации технической базы: нам важен ваш номер. Менеджер уточнит район, задачу и предложит честный вариант подключения.",
  tariffs = [],
  selectedTariff = null,
  initialAddress = null,
  initialPhone = null,
  actionResult = undefined,
  staticPreview = false,
  formAction = "#callback-request"
} = Astro.props;

const optionLabels: Record<TariffOption, string> = {
  routerRent: "Нужен роутер",
  staticIp: "Нужен статический IP",
  tvPack: "Нужно ТВ"
};

const requestedTariff = tariffs.find((tariff) => tariff.slug === selectedTariff);
const defaultTariffSlug =
  requestedTariff?.slug ??
  tariffs.find((tariff) => tariff.isFeatured)?.slug ??
  tariffs[0]?.slug ??
  "";
const selectedTariffData = tariffs.find((tariff) => tariff.slug === defaultTariffSlug);
const selectedPrice = selectedTariffData ? calculateMonthlyPrice(selectedTariffData).total : null;
const selectedPriceLabel =
  selectedPrice !== null ? `${formatRubles(selectedPrice)} / мес. до дополнительных опций` : "";
const availableOptions = Array.from(new Set(tariffs.flatMap((tariff) => tariff.availableOptions)));
const formStartedAt = Date.now().toString();
const actionData = actionResult?.data;
const actionError = actionResult?.error;
const formStatusId = "lead-form-status";
const describedBy = actionData || actionError ? `lead-form-note ${formStatusId}` : "lead-form-note";

function getOptionHint(option: TariffOption): string {
  const optionPrice = tariffs
    .map(
      (tariff) =>
        calculateMonthlyPrice(tariff, [option]).options.find((item) => item.id === option)?.amount
    )
    .find((amount): amount is number => typeof amount === "number");

  return optionPrice ? `+${formatRubles(optionPrice)} / мес.` : "по выбранному тарифу";
}
---

<section
  class="address-panel section-pad"
  id="callback-request"
  data-address-check
  data-static-preview={staticPreview ? "true" : undefined}
>
  <span class="visually-hidden" id="address-check" aria-hidden="true"></span>
  <div class="address-copy">
    <p class="eyebrow">Обратный звонок</p>
    <h2>{title}</h2>
    <p>{lead}</p>
    <ol class="mini-flow" aria-label="Шаги заявки">
      <li>Телефон</li>
      <li>Живой звонок</li>
      <li>Понятное предложение</li>
      <li>Подключение без сюрпризов</li>
    </ol>
    {
      selectedTariffData && selectedPrice !== null && (
        <div class="price-summary" data-price-summary aria-live="polite">
          <span>Ориентир для разговора</span>
          <strong data-price-title>{selectedTariffData.title}</strong>
          <p data-price-value>{selectedPriceLabel}</p>
        </div>
      )
    }
  </div>
  <form
    class="lead-form"
    id="lead-form"
    method="post"
    action={staticPreview ? "#callback-request" : formAction}
    aria-describedby={describedBy}
  >
    {
      actionData && (
        <div class="form-status is-success" id={formStatusId} role="status" tabindex="-1">
          <strong>{actionData.message}</strong>
          <span>Номер заявки: {actionData.leadId}</span>
          <span>
            Специалист перезвонит, уточнит детали и предложит вариант. Ориентир:{" "}
            {actionData.tariffTitle}, {formatRubles(actionData.monthlyTotal)} / мес.
          </span>
        </div>
      )
    }
    {
      actionError && (
        <div class="form-status is-error" id={formStatusId} role="alert" tabindex="-1">
          <strong>Заявка не отправлена</strong>
          <span>
            {actionError.message ??
              "Проверьте телефон, адрес, тариф и согласие на обработку данных."}
          </span>
        </div>
      )
    }

    <input name="sourcePath" type="hidden" value={Astro.url.pathname} />
    <input name="formStartedAt" type="hidden" value={formStartedAt} />
    <label class="visually-hidden">
      <span>Оставьте это поле пустым</span>
      <input name="website" type="text" tabindex="-1" autocomplete="off" />
    </label>

    <fieldset class="form-group">
      <legend>Телефон для звонка</legend>
      <div class="contact-grid">
        <label>
          <span>Телефон</span>
          <input
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            placeholder="+7"
            value={initialPhone ?? ""}
            required
          />
        </label>
        <label>
          <span>Имя, если удобно</span>
          <input name="name" type="text" autocomplete="name" placeholder="Как к вам обращаться" />
        </label>
      </div>
    </fieldset>

    {
      tariffs.length > 0 && (
        <fieldset class="form-group">
          <legend>Ориентир по тарифу</legend>
          <div class="choice-grid">
            {tariffs.map((tariff) => {
              const price = calculateMonthlyPrice(tariff);

              return (
                <label
                  class:list={["choice-card", { "is-selected": tariff.slug === defaultTariffSlug }]}
                  data-tariff-title={tariff.title}
                  data-tariff-price={`${formatRubles(price.total)} / мес. до дополнительных опций`}
                  data-available-options={tariff.availableOptions.join(" ")}
                >
                  <input
                    name="tariff"
                    type="radio"
                    value={tariff.slug}
                    checked={tariff.slug === defaultTariffSlug}
                  />
                  <span>
                    <strong>{tariff.title}</strong>
                    <small>{tariff.speedDownload} Мбит/с</small>
                    <em>{formatRubles(price.total)} / мес.</em>
                  </span>
                </label>
              );
            })}
          </div>
        </fieldset>
      )
    }

    {
      availableOptions.length > 0 && (
        <fieldset class="form-group">
          <legend>Пожелания к подключению</legend>
          <div class="option-grid">
            {availableOptions.map((option) => {
              const optionHint = getOptionHint(option);

              return (
                <label class="option-choice" data-option={option}>
                  <input name="options" type="checkbox" value={option} />
                  <span>
                    <strong>{optionLabels[option]}</strong>
                    <small data-option-hint data-default-hint={optionHint}>
                      {optionHint}
                    </small>
                  </span>
                </label>
              );
            })}
          </div>
        </fieldset>
      )
    }

    <fieldset class="form-group">
      <legend>Район или адрес, если уже знаете</legend>
      <label>
        <span>Адрес не обязателен</span>
        <input
          name="address"
          type="text"
          autocomplete="street-address"
          placeholder="Например: ФМР, ул. Красная, частный дом"
          value={initialAddress ?? ""}
        />
      </label>
    </fieldset>

    <label class="consent-check">
      <input name="consent" type="checkbox" value="true" required />
      <span>
        Согласен на обработку персональных данных для обратного звонка и подготовки предложения.
      </span>
    </label>

    <button type="submit">Жду звонка</button>
    <p class="form-note" id="lead-form-note">
      Достаточно телефона. Адрес, тариф и дополнительные пожелания можно уточнить уже в разговоре со
      специалистом Kubtel.
    </p>
  </form>
</section>

<script>
  const panel = document.querySelector("[data-address-check]");

  if (panel) {
    const params = new URLSearchParams(window.location.search);
    const requestedAddress = params.get("address");
    const requestedPhone = params.get("phone");
    const requestedTariff = params.get("tariff");
    const addressInput = panel.querySelector<HTMLInputElement>('input[name="address"]');
    const phoneInput = panel.querySelector<HTMLInputElement>('input[name="phone"]');
    const formStatus = panel.querySelector<HTMLElement>("#lead-form-status");
    const tariffInputs = Array.from(
      panel.querySelectorAll<HTMLInputElement>('input[name="tariff"]')
    );

    if (formStatus) {
      formStatus.focus({ preventScroll: true });
    }

    if (requestedAddress && addressInput) {
      addressInput.value = requestedAddress;
    }

    if (requestedPhone && phoneInput) {
      phoneInput.value = requestedPhone;
    }

    const requestedInput = tariffInputs.find((input) => input.value === requestedTariff);
    if (requestedInput) {
      requestedInput.checked = true;
    }

    const activeInput = requestedInput ?? tariffInputs.find((input) => input.checked);

    if (activeInput) {
      syncSelectedTariff(activeInput);
    }

    tariffInputs.forEach((input) => {
      input.addEventListener("change", () => syncSelectedTariff(input));
    });

    const form = panel.querySelector<HTMLFormElement>("#lead-form");

    if (panel.getAttribute("data-static-preview") === "true" && form) {
      form.addEventListener("submit", (event) => {
        if (!form.checkValidity()) {
          return;
        }

        event.preventDefault();
        showStaticPreviewStatus(form);
      });
    }
  }

  function syncSelectedTariff(input: HTMLInputElement) {
    const panel = input.closest("[data-address-check]");
    const choice = input.closest(".choice-card") as HTMLElement | null;
    const summary = panel?.querySelector<HTMLElement>("[data-price-summary]");
    const title = summary?.querySelector<HTMLElement>("[data-price-title]");
    const value = summary?.querySelector<HTMLElement>("[data-price-value]");
    const supportedOptions = new Set(
      (choice?.dataset.availableOptions ?? "").split(" ").filter(Boolean)
    );

    panel?.querySelectorAll(".choice-card").forEach((item) => item.classList.remove("is-selected"));
    choice?.classList.add("is-selected");

    if (choice && title && value) {
      title.textContent = choice.dataset.tariffTitle ?? "";
      value.textContent = choice.dataset.tariffPrice ?? "";
    }

    panel?.querySelectorAll<HTMLElement>("[data-option]").forEach((item) => {
      const option = item.dataset.option ?? "";
      const checkbox = item.querySelector<HTMLInputElement>('input[type="checkbox"]');
      const hint = item.querySelector<HTMLElement>("[data-option-hint]");
      const isSupported = supportedOptions.has(option);

      item.classList.toggle("is-disabled", !isSupported);
      item.setAttribute("aria-disabled", String(!isSupported));

      if (checkbox) {
        checkbox.disabled = !isSupported;

        if (!isSupported) {
          checkbox.checked = false;
        }
      }

      if (hint) {
        hint.textContent = isSupported
          ? (hint.dataset.defaultHint ?? "")
          : "Недоступно для выбранного тарифа";
      }
    });
  }

  function showStaticPreviewStatus(form: HTMLFormElement) {
    const existingStatus = form.querySelector<HTMLElement>("#lead-form-status");
    const status = existingStatus ?? document.createElement("div");
    const tariff = form.querySelector<HTMLInputElement>('input[name="tariff"]:checked');
    const choice = tariff?.closest(".choice-card") as HTMLElement | null;
    const title = choice?.dataset.tariffTitle ?? "выбранный тариф";
    const price = choice?.dataset.tariffPrice ?? "стоимость уточним на звонке";

    status.className = "form-status is-success";
    status.id = "lead-form-status";
    status.setAttribute("role", "status");
    status.setAttribute("tabindex", "-1");
    status.replaceChildren(
      createStatusLine("strong", "Демо-заявка принята в онлайн-превью."),
      createStatusLine("span", "В боевом режиме менеджер получает телефон и перезванивает."),
      createStatusLine("span", `Ориентир: ${title}, ${price}.`)
    );

    if (!existingStatus) {
      form.prepend(status);
    }

    status.focus({ preventScroll: true });
  }

  function createStatusLine(tagName: "strong" | "span", text: string) {
    const element = document.createElement(tagName);
    element.textContent = text;

    return element;
  }
</script>
